# Google AI Studio (Gemini) API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Model used for per-entry extraction. Flash is fast + cheap and enough for this.
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000

# Set to "true" to skip all LLM calls and use the deterministic fallback extractor.
# Useful for offline dev, CI, or demonstrating that the pipeline degrades safely.
DISABLE_LLM=false

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
