<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= h.hotel.name || h.hotel.id %> — Night handover <%= h.targetDate %></title>
  <style>
    :root {
      --crit: #b00020; --high: #c2410c; --normal: #1d4ed8; --low: #6b7280;
      --bg: #f7f7f8; --card: #fff; --line: #e5e7eb; --ink: #111827; --muted: #6b7280;
    }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--ink);
      font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    .wrap { max-width: 820px; margin: 0 auto; padding: 24px 16px 64px; }
    header h1 { margin: 0 0 4px; font-size: 22px; }
    .sub { color: var(--muted); font-size: 13px; }
    .dates { margin: 12px 0; font-size: 13px; }
    .dates a { display: inline-block; margin-right: 6px; padding: 2px 8px; border: 1px solid var(--line);
      border-radius: 999px; text-decoration: none; color: var(--normal); background: #fff; }
    .dates a.active { background: var(--normal); color: #fff; border-color: var(--normal); }
    .counts { display: flex; gap: 8px; flex-wrap: wrap; margin: 16px 0; }
    .counts .pill { background: var(--card); border: 1px solid var(--line); border-radius: 8px;
      padding: 8px 12px; font-size: 13px; }
    .counts .pill b { font-size: 18px; display: block; }
    .review { background: #fff7ed; border: 1px solid #fed7aa; border-left: 4px solid var(--high);
      border-radius: 8px; padding: 12px 14px; margin: 16px 0; }
    .review h2 { margin: 0 0 8px; font-size: 14px; color: var(--high); }
    .review li { font-size: 13px; margin: 3px 0; }
    h2.section { margin: 28px 0 10px; font-size: 16px; border-bottom: 2px solid var(--line); padding-bottom: 6px; }
    .empty { color: var(--muted); font-size: 13px; font-style: italic; }
    .card { background: var(--card); border: 1px solid var(--line); border-left-width: 4px;
      border-radius: 8px; padding: 12px 14px; margin: 10px 0; }
    .card.critical { border-left-color: var(--crit); }
    .card.high { border-left-color: var(--high); }
    .card.normal { border-left-color: var(--normal); }
    .card.low { border-left-color: var(--low); }
    .card .top { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
    .card .title { font-weight: 600; }
    .badge { font-size: 11px; text-transform: uppercase; letter-spacing: .03em; padding: 1px 7px;
      border-radius: 999px; color: #fff; }
    .badge.critical { background: var(--crit); }
    .badge.high { background: var(--high); }
    .badge.normal { background: var(--normal); }
    .badge.low { background: var(--low); }
    .tag { font-size: 11px; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 1px 7px; }
    .tag.flag { color: var(--high); border-color: #fed7aa; background: #fff7ed; }
    .why { color: var(--muted); font-size: 12.5px; margin: 6px 0 2px; }
    .summary { margin: 6px 0; }
    details { margin-top: 6px; }
    summary { cursor: pointer; font-size: 12.5px; color: var(--normal); }
    .src { font-size: 12.5px; border-top: 1px dashed var(--line); margin-top: 8px; padding-top: 8px; }
    .src .q { color: #374151; }
    .src .meta { color: var(--muted); }
    .src .xlat { color: var(--high); }
    footer { margin-top: 36px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--line); padding-top: 12px; }
  </style>
</head>
<body>
<div class="wrap">
  <header>
    <h1><%= h.hotel.name || h.hotel.id %> — Night-shift handover</h1>
    <div class="sub">Morning of <strong><%= h.targetDate %></strong>
      · <%= h.hotel.rooms ? h.hotel.rooms + ' rooms' : '' %>
      · generated <%= h.generatedAt %></div>
    <% if (h.availableDates && h.availableDates.length) { %>
      <div class="dates">Mornings:
        <% h.availableDates.forEach(function(d){ %><a class="<%= d === h.targetDate ? 'active' : '' %>" href="?date=<%= d %>"><%= d %></a><% }); %>
      </div>
    <% } %>
  </header>

  <div class="counts">
    <div class="pill"><b><%= h.counts.onFire %></b> on fire</div>
    <div class="pill"><b><%= h.counts.pending %></b> pending</div>
    <div class="pill"><b><%= h.counts.fyi %></b> FYI</div>
    <div class="pill"><b><%= h.counts.reviewFlags %></b> to review</div>
    <div class="pill"><b><%= h.counts.stillOpen %></b> still open</div>
    <div class="pill"><b><%= h.counts.newlyResolved %></b> resolved o/n</div>
    <div class="pill"><b><%= h.counts.newTonight %></b> new tonight</div>
  </div>

  <% if (h.reviewFlags && h.reviewFlags.length) { %>
    <div class="review">
      <h2>⚠ Needs review — do not take at face value</h2>
      <ul>
        <% h.reviewFlags.forEach(function(r){ %>
          <li><strong><%= r.label %></strong><%= r.room ? ' (room ' + r.room + ')' : '' %> — <%= r.note %> <span class="meta">[<%= r.flag %>]</span></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <%
    function renderSection(title, items) { %>
      <h2 class="section"><%= title %></h2>
      <% if (!items.length) { %><p class="empty">Nothing here.</p><% } %>
      <% items.forEach(function(i){ %>
        <div class="card <%= i.severity %>">
          <div class="top">
            <span class="badge <%= i.severity %>"><%= i.severity %></span>
            <span class="title"><%= i.label %></span>
            <% if (i.room) { %><span class="tag">room <%= i.room %></span><% } %>
            <% if (i.guest) { %><span class="tag"><%= i.guest %></span><% } %>
            <span class="tag"><%= i.lifecycleLabel %></span>
            <% if (i.carriedOver && i.nightsOpen > 1) { %><span class="tag">open <%= i.nightsOpen %> nights</span><% } %>
            <% i.flags.forEach(function(f){ %><span class="tag flag"><%= f %></span><% }); %>
          </div>
          <div class="summary"><%= i.summary %></div>
          <div class="why">Why: <%= i.reasons.join('; ') %></div>
          <details>
            <summary>Sources (<%= i.timeline.length %>) — every line above traces here</summary>
            <% i.timeline.forEach(function(t){ %>
              <div class="src">
                <div class="meta"><%= t.sourceId %> · <%= t.source %> · <%= t.shiftMorning %> · <%= t.status %><%= t.grounded ? '' : ' · UNVERIFIED' %></div>
                <div class="q">“<%= t.quote %>”</div>
                <% if (t.language && t.language !== 'en' && t.language !== 'unknown') { %>
                  <div class="xlat">↳ translated (<%= t.language %>): <%= t.detail %></div>
                <% } %>
              </div>
            <% }); %>
          </details>
        </div>
      <% }); %>
    <% }
  %>

  <% renderSection('🔥 On fire', h.sections.onFire); %>
  <% renderSection('⏳ Pending a decision', h.sections.pending); %>
  <% renderSection('ℹ️ FYI / handled overnight', h.sections.fyi); %>

  <footer>
    Every statement is grounded in a verbatim source quote (see “Sources”). Contradictory or
    incomplete entries are flagged, not resolved silently. Instructions embedded in guest/staff
    text are treated as data, never executed. Hotel <code><%= h.hotel.id %></code>, night <code><%= h.targetDate %></code>.
  </footer>
</div>
</body>
</html>
